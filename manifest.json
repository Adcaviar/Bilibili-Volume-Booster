{
  "manifest_version": 3,
  "name": "哔哩哔哩音量增强-Bilibili Volume Booster",
  "description": "【哔哩哔哩网页音量增强：突破播放器 100% 上限，支持智能音量自适应与 1%–500% 手动调节，一键开关，专为听不清的视频而生。】",
  "version": "0.0.3",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "src/popup.html",
    "default_title": "Bilibili Volume Booster"
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "toggle-boost": {
      "suggested_key": "Alt+Shift+U",
      "description": "开关哔哩哔哩音量增强"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["src/shortcut.js", "src/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "host_permissions": [
    "*://*.bilibili.com/*"
  ],
  "permissions": [
    "activeTab",
    "notifications",
    "offscreen",
    "storage",
    "scripting",
    "tabCapture",
    "tabs"
  ]
}
